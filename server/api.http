{
  "current": {
    "name": "Custom Location",
    "sys": { "country": "NP" },
    "main": {
      "temp": 4,
      "feels_like": 2,
      "humidity": 80,
      "pressure": 1013
    },
    "wind": { "speed": 5 },
    "weather": [{ "main": "Rain", "description": "light rain", "id": 500 }],
    "rain": { "1h": 8, "3h": 15 }
  },
  "forecast": null
}

